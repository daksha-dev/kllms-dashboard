# Google Gemini (AI Studio) — required
GEMINI_API_KEY=

# Search fallback — pick one or both
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Notion — used for multi-user auth
NOTION_TOKEN=
# Notion database id where users live. Schema:
#   Title        (title)         -> email
#   PasswordHash (rich_text)     -> bcrypt hash
#   Name         (rich_text)     -> display name
#   Role         (select)        -> admin | user
#   CreatedAt    (created_time)  -> auto
NOTION_USERS_DB_ID=

# Auth — random 32+ char string used to sign session cookies
AUTH_SECRET=replace-with-a-long-random-string-please-32-chars-min

# Optional: seed admin user on first run (email + plain password)
# After first successful login, change this user's password in Notion.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
